#!/bin/sh
set -e

case "$1" in
    remove|purge)
        if [ -f /usr/share/pam-configs/secureEye ] && command -v pam-auth-update >/dev/null 2>&1 && \
           { [ -z "${DPKG_MAINTSCRIPT_PACKAGE:-}" ] || [ "${DPKG_MAINTSCRIPT_PACKAGE:-}" = "libpam-secureeye" ]; }; then
            pam-auth-update --package || true
        fi
        ;;
esac

exit 0
